{
  "name": "arcade-demo-tanstack",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:setup:local": "npm run db:migrate:local && npm run db:seed:local",
    "db:seed:local": "for f in seed seed.extra seed.event-venues seed.venue-repairs seed.expert-notes seed.snapback-tips seed.jack seed.crew-citifield; do wrangler d1 execute DB --local --file db/$f.generated.sql || exit 1; done",
    "db:seed:remote": "for f in seed seed.extra seed.event-venues seed.venue-repairs seed.expert-notes seed.snapback-tips seed.jack seed.crew-citifield; do wrangler d1 execute DB --remote --file db/$f.generated.sql || exit 1; done",
    "db:ingest": "node scripts/ingest.mjs && node scripts/ingest-extra.mjs",
    "db:seed:generate": "node scripts/build-expert-notes.mjs && node scripts/seed-snapback-tips.mjs && node scripts/seed-jack.mjs && node scripts/seed-event-venues.mjs && node scripts/seed-crew-citifield.mjs && node scripts/repair-venue-links.mjs",
    "db:seed:akash:local": "node scripts/seed-akash-deansmith.mjs && wrangler d1 execute DB --local --file db/seed.akash-deansmith.generated.sql",
    "build:city-coords": "node scripts/build-city-coords.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "@shadcn/react": "^0.2.1",
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "html-to-image": "^1.11.13",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.545.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "^19.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.81.0",
    "react-resizable-panels": "^4.12.1",
    "recharts": "^3.8.0",
    "satori": "^0.12.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.99.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
