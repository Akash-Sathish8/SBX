{
  "name": "arcade-demo-tanstack",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "db:ingest": "node scripts/ingest.mjs",
    "db:ingest:extra": "node scripts/ingest-extra.mjs",
    "db:schema:local": "wrangler d1 execute DB --local --file db/schema.sql",
    "db:seed:local": "wrangler d1 execute DB --local --file db/seed.generated.sql && wrangler d1 execute DB --local --file db/seed.extra.generated.sql",
    "db:setup:local": "npm run db:schema:local && npm run db:ingest && npm run db:ingest:extra && npm run db:seed:local",
    "db:schema:remote": "wrangler d1 execute DB --remote --file db/schema.sql",
    "db:seed:remote": "wrangler d1 execute DB --remote --file db/seed.generated.sql && wrangler d1 execute DB --remote --file db/seed.extra.generated.sql",
    "db:expert-notes": "node scripts/build-expert-notes.mjs",
    "db:seed:notes:local": "wrangler d1 execute DB --local --file db/seed.expert-notes.generated.sql",
    "db:seed:notes:remote": "wrangler d1 execute DB --remote --file db/seed.expert-notes.generated.sql",
    "db:seed:snapback-tips": "node scripts/seed-snapback-tips.mjs",
    "db:seed:snapback-tips:local": "wrangler d1 execute DB --local --file db/seed.snapback-tips.generated.sql",
    "db:seed:snapback-tips:remote": "wrangler d1 execute DB --remote --file db/seed.snapback-tips.generated.sql",
    "db:migrate:profiles:local": "wrangler d1 execute DB --local --file db/migrate-001-profiles.sql",
    "db:migrate:profiles:remote": "wrangler d1 execute DB --remote --file db/migrate-001-profiles.sql",
    "db:migrate:displayname:local": "wrangler d1 execute DB --local --file db/migrate-002-display-name.sql",
    "db:migrate:displayname:remote": "wrangler d1 execute DB --remote --file db/migrate-002-display-name.sql",
    "db:migrate:reviewvotes:local": "wrangler d1 execute DB --local --file db/migrate-003-review-votes.sql",
    "db:migrate:reviewvotes:remote": "wrangler d1 execute DB --remote --file db/migrate-003-review-votes.sql",
    "db:migrate:tipvotes:local": "wrangler d1 execute DB --local --file db/migrate-004-tip-votes.sql",
    "db:migrate:tipvotes:remote": "wrangler d1 execute DB --remote --file db/migrate-004-tip-votes.sql",
    "db:seed:jack": "node scripts/seed-jack.mjs",
    "db:seed:jack:local": "wrangler d1 execute DB --local --file db/seed.jack.generated.sql",
    "db:seed:jack:remote": "wrangler d1 execute DB --remote --file db/seed.jack.generated.sql",
    "db:seed:akash": "node scripts/seed-akash-deansmith.mjs",
    "db:seed:akash:local": "wrangler d1 execute DB --local --file db/seed.akash-deansmith.generated.sql",
    "db:seed:akash:remote": "wrangler d1 execute DB --remote --file db/seed.akash-deansmith.generated.sql",
    "db:seed:event-venues": "node scripts/seed-event-venues.mjs",
    "db:seed:event-venues:local": "wrangler d1 execute DB --local --file db/seed.event-venues.generated.sql",
    "db:seed:event-venues:remote": "wrangler d1 execute DB --remote --file db/seed.event-venues.generated.sql",
    "db:repair:venues": "node scripts/repair-venue-links.mjs",
    "db:repair:venues:local": "wrangler d1 execute DB --local --file db/seed.venue-repairs.generated.sql",
    "db:repair:venues:remote": "wrangler d1 execute DB --remote --file db/seed.venue-repairs.generated.sql",
    "build:city-coords": "node scripts/build-city-coords.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "html-to-image": "^1.11.13",
    "jose": "^5.10.0",
    "lucide-react": "^0.545.0",
    "maplibre-gl": "^4.7.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "satori": "^0.12.2",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.99.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
